# Copy this to .env (or set as real env vars / platform secrets) before running.

APP_ENV=development

# "mock" = synthetic data, safe anywhere, no network needed. Good default for
# local dev, demos, and CI. Switch to "psxdata" once you're ready to hit the
# real (unofficial, delayed) PSX scraper - requires outbound internet access
# to psx.com.pk from wherever this service runs.
PROVIDER=mock

DEFAULT_SYMBOLS=OGDC,PPL,HBL,ENGRO,LUCK
POLL_SECONDS=60
OFF_HOURS_POLL_SECONDS=300
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

PUBLIC_READ=true
ADMIN_BEARER_TOKEN=replace-me-with-a-long-random-string

STALE_AFTER_SECONDS=1200
TZ=Asia/Karachi
